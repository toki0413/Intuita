[layer_names]

2d_physics/layer_1="construction"
2d_physics/layer_2="element"
2d_physics/layer_3="fog"
2d_physics/layer_4="proof_node"

[rendering]

textures/vram_compression/import_etc2_astc=true
textures/vram_compression/import_s3tc_bptc=true
anti_aliasing/quality/msaa_3d=0
anti_aliasing/quality/screen_space_aa=0
rendering/anti_aliasing/quality/use_taa=true
rendering/lights_and_shadows/directional_shadow/size=1024
rendering/lights_and_shadows/directional_shadow/soft_shadow_filter_quality=1
rendering/lights_and_shadows/positional_shadow/soft_shadow_filter_quality=1
