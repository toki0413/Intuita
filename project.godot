; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Intuita"
config/description="存在即被构造 - A mathematical construction game"
config/version="0.2.0"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://icon.svg"

[autoload]

GameLogger="*res://scripts/autoload/00_game_logger.gd"
AchievementManager="*res://scripts/autoload/04_achievement_manager.gd"
SettingsManager="*res://scripts/autoload/02_settings_manager.gd"
I18nManager="*res://scripts/autoload/03_i18n_manager.gd"
LLMBridge="*res://scripts/autoload/llm_bridge.gd"
ErrorHandler="*res://scripts/autoload/01_error_handler.gd"
GameState="*res://scripts/autoload/game_state.gd"
ConservationEngine="*res://scripts/autoload/07_conservation_engine.gd"
MorphismSystem="*res://scripts/autoload/11_morphism_system.gd"
FogSystem="*res://scripts/autoload/08_fog_system.gd"
ProofTree="*res://scripts/autoload/10_proof_tree.gd"
VerificationPipeline="*res://scripts/autoload/12_verification_pipeline.gd"
TutorialManager="*res://scripts/autoload/09_tutorial_manager.gd"
LevelManager="*res://scripts/autoload/05_level_manager.gd"
SoundManager="*res://scripts/autoload/06_sound_manager.gd"
LeaderboardManager="*res://scripts/autoload/13_leaderboard_manager.gd"
ProceduralAudio="*res://scripts/autoload/procedural_audio.gd"
AIAssistant="*res://scripts/autoload/ai_assistant.gd"
SelfEvolve="*res://scripts/autoload/self_evolve.gd"
DailyChallenge="*res://scripts/autoload/daily_challenge.gd"
MaterialCodex="*res://scripts/autoload/material_codex.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
ParticlePool="*res://scripts/autoload/particle_pool.gd"
UiAnimator="*res://scripts/autoload/ui_animator.gd"
PerformanceBenchmark="res://scripts/autoload/performance_benchmark.gd"
LODManager="*res://scripts/autoload/lod_manager.gd"
StructureCodex="*res://scripts/autoload/11_structure_codex.gd"
EvolutionTree="*res://scripts/autoload/14_evolution_tree.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/gdUnit4/plugin.cfg")

[gdscript]

warnings/inferenced_declaration=0
warnings/unsafe_method_access=0
warnings/unsafe_property_access=0
warnings/unsafe_cast=0
warnings/unsafe_call_argument=0
warnings/return_value_discarded=0

[gdunit4]

report/verbose_orphans=false

[gui]

theme/custom="res://resources/themes/intuita_theme.tres"

