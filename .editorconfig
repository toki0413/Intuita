# EditorConfig - 统一编码风格
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4

[*.{gd, gdscript]
indent_style = tab
indent_size = 4

[*.rs]
indent_style = tab
indent_size = 4
max_line_length = 100

[*.{yml, yaml}]
indent_style = space
indent_size = 2

[*.{toml, json}]
indent_style = space
indent_size = 2

[*.{md, txt}]
trim_trailing_whitespace = false

[*.tres]
indent_style = tab
indent_size = 4
